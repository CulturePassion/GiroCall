# Supabase Configuration (Flutter — use "Connect → Flutter" in the dashboard)
# Get these from: https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api
SUPABASE_URL=https://your-project.supabase.co
# Use your publishable key (sb_publishable_...) or legacy anon key
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional — public URL for digital business cards (defaults to https://girocall.com)
# APP_BASE_URL=https://girocall.com

# Optional — for `make setup-db` (Database > Connection string > URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional — for `npm run setup-db` (Account > Access Tokens)
# SUPABASE_ACCESS_TOKEN=your-personal-access-token