# GiroCall Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Supabase (required for app) ─────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://gtvpsukmmjhszpopulfe.supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key

# Remote deploy / migrations (pick ONE method — not the anon key above)
SUPABASE_PROJECT_REF=gtvpsukmmjhszpopulfe
# Personal access token: https://supabase.com/dashboard/account/tokens (starts with sbp_)
SUPABASE_ACCESS_TOKEN=
# Or direct Postgres URL from Dashboard → Settings → Database
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or run: supabase login  (CLI session — no token in .env needed)

# ── Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets) ───
CRON_SECRET=generate-a-long-random-string
FCM_SERVER_KEY=your-firebase-legacy-server-key

# ── App URLs ────────────────────────────────────────────────────────────────
APP_BASE_URL=https://girocall.com

# ── Sentry (optional — production error reporting) ──────────────────────────
# Create a project at https://sentry.io → Client Keys (DSN)
# SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000

# ── Optional: fixed auth redirect for local web dev (must match allow-list) ───
# make run uses --web-port=62792; set this if you use a different port.
# WEB_AUTH_REDIRECT_URL=http://localhost:62792